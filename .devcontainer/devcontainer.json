{
  "name": "daily-agenda-email",

  "build": {
    "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
    "context": "${localWorkspaceFolder}"
  },

  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/devuser/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/devuser/.claude.json,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/devuser/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/tmp/.host-gitconfig,type=bind,readonly",
    "source=${localWorkspaceFolder}/.devcontainer/setup.sh,target=/tmp/devcontainer-setup.sh,type=bind,readonly"
  ],

  "initializeCommand": "docker build --target dev -t daily-agenda-email-dev ${localWorkspaceFolder}",

  "postCreateCommand": "bash /tmp/devcontainer-setup.sh",

  "remoteUser": "devuser",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
  "workspaceFolder": "/app",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
